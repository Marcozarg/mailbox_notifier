// arduino_secrets.h.example — TEMPLATE
//
// Copy this file to `arduino_secrets.h` in the same directory, then replace
// the placeholder values below with your real credentials. The real
// `arduino_secrets.h` is gitignored so your secrets never leave your machine.

// WiFi network the receiver joins (must reach the MQTT broker / HA).
#define SECRET_SSID  "your-wifi-ssid"
#define SECRET_PASS  "your-wifi-password"

// MQTT broker — typically your Home Assistant Mosquitto add-on.
#define MQTTUSER     "your-mqtt-user"
#define MQTTPASS     "your-mqtt-password"
#define MQTTBROKER   "192.168.xxx.xxx"
