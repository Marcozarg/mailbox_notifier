// arduino_secrets.h.example — TEMPLATE (sender)
//
// Copy this file to `arduino_secrets.h` in the same directory, then replace
// the placeholder values below with your real credentials. The real
// `arduino_secrets.h` is gitignored so your secrets never leave your machine.
//
// The sender has no WiFi or MQTT — only the AES key is needed here.

// AES-128 pre-shared key — must match the receiver's arduino_secrets.h exactly.
// Generate a fresh key with: python3 -c "import os; print(', '.join(f'0x{b:02X}' for b in os.urandom(16)))"
// Required for sender V2.3.0+ (AES-128-CTR encryption). Not used in earlier versions.
#define LORA_AES_KEY { 0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00 }
