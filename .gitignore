# --- Secrets — never commit credentials ---
# Real arduino_secrets.h files contain WiFi password + MQTT broker creds.
# Anyone cloning this repo copies arduino_secrets.h.example → arduino_secrets.h
# and fills in their own values.
**/arduino_secrets.h

